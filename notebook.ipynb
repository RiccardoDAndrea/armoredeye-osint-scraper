4e4bf-9389-466a-b8ba-b0462447c01b/AAABnspF7ug/AAABnSSvrFg/16x9-big/nyse-462.webp?width=768&quot;,&quot;urlL&quot;:&quot;https://images.tagesschau.de/image/28b4e4bf-9389-466a-b8ba-b0462447c01b/AAABnspF7ug/AAABnSSvrFg/16x9-big/nyse-462.webp?width=1280&quot;}}\"\\n         data-v-type=\"MediaPlayer\">\\n    </div>\\n\\n\\n    \\n\\n                                        \\n                                    \\n                                </div>\\n                                <div class=\"teaser-absatz__teaserinfo columns eight m-nine\" role=\"complementary\" aria-label=\"Kasten\" >\\n                                    <a class=\"teaser-absatz__link\"\\n                                       href=\"/wirtschaft/boerse/spacex-openai-anthropic-ki-boersengang-100.html\">\\n                                        <div class=\"teaser-absatz__teaserheadline\">\\n                                            <p class=\"teaser-absatz__topline-container\">\\n                                                \\n                                                <span class=\"label label--standard-primary\">\\n                                                    <strong>Analyse</strong>\\n                                                </span>\\n                                                \\n                                                \\n                                                    <span class=\"teaser-absatz__date\">15.06.2026</span>\\n                                                \\n                                            </p>\\n                                            <h3 class=\"teaser-absatz__headline-wrapper\">\\n                                                <span class=\"teaser-absatz__topline\">Nach SpaceX-Rekordstart</span>\\n                                                <span class=\"teaser-absatz__headline\">Wettlauf der KI-Giganten an die Börse</span>\\n                                            </h3>\\n                                        </div>\\n                                        <div class=\"teaser-absatz__shorttext-container\">\\n                                            <p class=\"teaser-absatz__shorttext\">Nach dem Rekordstart von SpaceX drängen OpenAI und Anthropic an die Börse. Doch das Kapital ist begrenzt.\\n                                                <span class=\"link-extend\">mehr</span>\\n                                            </p>\\n                                        </div>\\n                                    </a>\\n                                </div>\\n                            \\n                        </div>\\n                    \\n                </div>\\n                <div class=\"copytext-element-wrapper__divider columns twelve m-ten m-offset-one l-eight l-offset-two\">\\n                    <span class=\"divider\"></span>\\n                </div>\\n            </div>\\n        \\n    \\n\\n        \\n    \\n\\n    \\n\\n        \\n    \\n        \\n        \\n    \\n    \\n    \\n\\n    \\n        \\n            \\n    \\n    \\n    <h2 id=\"Hoehepunkt-der-Inflation-bereits-ueberschritten\" class=\"meldung__subhead columns twelve  m-ten  m-offset-one l-eight l-offset-two liveblog--anchor\">Höhepunkt der Inflation bereits überschritten?</h2>\\n\\n        \\n    \\n\\n    \\n        \\n    \\n    \\n\\n    \\n\\n    \\n        \\n    \\n    \\n\\n    \\n\\n        \\n    \\n        \\n        \\n    \\n    \\n    \\n\\n    \\n        \\n            \\n    \\n    <p class=\"textabsatz m-ten m-offset-one l-eight l-offset-two columns twelve\">Hinzu kommt nun die Hoffnung auf sinkende Energiepreise: Warsh könnte daher im Offenmarktausschuss argumentieren, dass der Höhepunkt des Ölpreisschocks überschritten sei und die Fed durch den kurzfristigen Inflationsanstieg \"hindurchschauen\" sollte.</p>\\n\\n        \\n    \\n\\n    \\n        \\n    \\n    \\n\\n    \\n\\n    \\n        \\n    \\n    \\n\\n    \\n\\n        \\n    \\n        \\n        \\n    \\n    \\n    \\n\\n    \\n        \\n            \\n    \\n    <p class=\"textabsatz m-ten m-offset-one l-eight l-offset-two columns twelve\">\"Von jetzt an wird es besser, wir können also noch einmal abwarten\" - mit dieser Botschaft könne Warsh jene Notenbanker beruhigen, die zuletzt höhere Zinsen gefordert hätten, sagt BNP-Experte Kemper.</p>\\n\\n        \\n    \\n\\n    \\n        \\n    \\n    \\n\\n    \\n\\n    \\n        \\n    \\n    \\n\\n    \\n\\n        \\n    \\n        \\n        \\n    \\n    \\n    \\n\\n    \\n        \\n            \\n    \\n    \\n\\n        \\n    \\n\\n    \\n        \\n    \\n    \\n\\n    \\n\\n    \\n        \\n    \\n    \\n        \\n    \\n        \\n        \\n        \\n            \\n    \\n    \\n    \\n    \\n    \\n    \\n    \\n        \\n            \\n            <div class=\"copytext-element-wrapper columns twelve copytext-element-wrapper--overlap  \">\\n                <div class=\"copytext-element-wrapper__divider columns twelve m-ten m-offset-one l-eight l-offset-two\">\\n                    <span class=\"divider\"></span>\\n                </div>\\n                <div class=\"columns twelve l-nine l-offset-one\">\\n                    \\n                        <div class=\"teaser-absatz columns\">\\n                            \\n                                <div class=\"teaser-absatz__media columns four m-three\">\\n                                    \\n                                        \\n                                            \\n    \\n    \\n    <div class=\"ts-picture__poster-wrapper\">\\n        <picture class=\"ts-picture ts-picture--list\">\\n            <source type=\"image/webp\" media=\"(max-width: 440px)\" srcset=\"https://images.tagesschau.de/image/4b43d17c-9953-4683-b759-2fc25b78d22f/AAABns-mXzs/AAABnSStZVI/1x1-small/spritpreise-204.webp?width=256\"/>\\n            <source type=\"image/webp\" media=\"(max-width: 900px)\" srcset=\"https://images.tagesschau.de/image/4b43d17c